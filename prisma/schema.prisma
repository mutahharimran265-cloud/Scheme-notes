// SchemNotes data model — see README for an overview.
// SQLite for local dev (the committed default). Cloud deploys build with
// DB_PROVIDER=postgresql via scripts/use-db-provider.mjs — see DEPLOY.md.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev + Docker; the rhel target is Vercel's / other
  // serverless runtimes (Amazon Linux, OpenSSL 3).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id         String          @id @default(cuid())
  title      String
  ownerEmail String? // captured for the "my projects" dashboard; commenting stays login-free
  // Team workspace (Team plan). When teamId is set, access is governed by team
  // membership + per-project ProjectMember levels instead of the public link.
  team       Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId     String?
  visibility String          @default("public") // public (anyone with link) | private (members only)
  members    ProjectMember[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt
  files      SchematicFile[]
  revisions  Revision[]

  @@index([teamId])
  @@index([ownerEmail])
}

// A named schematic revision ("rev A", "v2.1"). Comments attach to a
// revision's file; new revisions can carry over outstanding comments.
model Revision {
  id        String          @id @default(cuid())
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  note      String?
  createdAt DateTime        @default(now())
  files     SchematicFile[]

  @@index([projectId])
}

model SchematicFile {
  id           String    @id @default(cuid())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  fileUrl      String
  fileType     String // rendered/served type: png | jpg | pdf | svg
  // For native EDA uploads (e.g. KiCad .kicad_sch) we render to SVG for viewing
  // but keep the uploaded source file so reviewers can download the original.
  originalUrl  String?
  originalName String?
  uploadedAt   DateTime  @default(now())
  revision     Revision? @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  revisionId   String?
  comments     Comment[]

  @@index([projectId])
  @@index([revisionId])
}

model Comment {
  id              String           @id @default(cuid())
  schematicFile   SchematicFile    @relation(fields: [schematicFileId], references: [id], onDelete: Cascade)
  schematicFileId String
  // Self-relation for threaded replies. A null parent = a top-level thread (has a pin).
  parent          Comment?         @relation("Replies", fields: [parentCommentId], references: [id])
  parentCommentId String?
  replies         Comment[]        @relation("Replies")
  authorName      String
  // Per-browser secret (localStorage) that proves ownership of an anonymous
  // comment, so the author can edit/delete it without an account.
  authorToken     String?
  body            String
  // Pin location as a percentage of the rendered image (survives zoom/resize).
  // Null for replies — they hang off the parent thread's pin.
  xPercent        Float?
  yPercent        Float?
  pageNumber      Int              @default(1)
  status          String           @default("open") // open, in_review, resolved, wontfix
  resolved        Boolean          @default(false)
  // Set when this comment was carried over from an earlier revision.
  carriedFrom     Comment?         @relation("CarriedComments", fields: [carriedFromId], references: [id], onDelete: SetNull)
  carriedFromId   String?
  carried         Comment[]        @relation("CarriedComments")
  // Engineer metadata: tags (JSON string array) + optional component link.
  tags            String           @default("[]")
  componentRef    String? // designator or net, e.g. "R12", "NET_VBUS"
  partNumber      String?
  datasheetUrl    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  // Edit history (version_history, Pro): one row appended per edit.
  versions        CommentVersion[]

  @@index([schematicFileId])
  @@index([parentCommentId])
  @@index([carriedFromId])
}

// Personal access tokens for the scriptable REST API + cloud sync. `email` is
// the owner (set when created while signed in) — it lets a cloud instance
// authenticate a sync client as a specific account.
model ApiToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  label      String
  email      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

// Where an account's local install pushes/pulls its cloud copy. One row per
// signed-in email; cloudToken is an API token minted on the cloud instance.
model SyncConfig {
  email      String    @id
  cloudUrl   String
  cloudToken String
  lastSyncAt DateTime?
  lastError  String?
  updatedAt  DateTime  @updatedAt
}

// Per-user billing plan, keyed by (normalized) email. A row is created/updated
// by the Stripe webhook on checkout. No row = free. The deployment-wide
// SCHEMNOTES_PLAN env acts as a floor/override — see src/lib/plan.ts.
model Account {
  email                String    @id
  plan                 String    @default("free") // free | pro | team
  // Priority-support flag (Team). Set by the billing webhook / team plan; drives
  // a dashboard badge + a support-routing hook. No support system is wired yet.
  prioritySupport      Boolean   @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Team workspaces (Team plan) — a shared workspace with members, roles, and
// pending email invites. Projects can be attached to a team; per-project access
// is refined by ProjectMember levels (viewer | commenter | admin).
// ---------------------------------------------------------------------------
model Team {
  id        String       @id @default(cuid())
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  invites   TeamInvite[]
  projects  Project[]
}

model TeamMember {
  id        String   @id @default(cuid())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  email     String
  role      String   @default("member") // owner | admin | member
  createdAt DateTime @default(now())

  @@unique([teamId, email])
  @@index([email])
}

model TeamInvite {
  id         String    @id @default(cuid())
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId     String
  email      String
  role       String    @default("member")
  token      String    @unique // accept-link token
  invitedBy  String
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@unique([teamId, email])
  @@index([email])
}

// Per-project access level for a specific member email. Overrides the base team
// role for that project (e.g. a member granted "admin" on one project).
model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  email     String
  level     String   @default("commenter") // viewer | commenter | admin
  createdAt DateTime @default(now())

  @@unique([projectId, email])
  @@index([email])
}

// Annotation edit history (version_history, Pro). One row per edit of a comment.
model CommentVersion {
  id        String   @id @default(cuid())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  body      String
  editedBy  String? // authorName (anonymous) or email (signed-in) that made the edit
  createdAt DateTime @default(now())

  @@index([commentId])
}
