# Copy this file to `.env` and adjust. The defaults below run SchemNotes
# locally on SQLite — no cloud, no accounts required. For a cloud deployment
# (Postgres + cross-device sync) see DEPLOY.md and the "Cloud" block at the end.

# ---------------------------------------------------------------------------
# Local development (default)
# ---------------------------------------------------------------------------

# Database backend: "sqlite" (local, default) or "postgresql" (cloud).
DB_PROVIDER="sqlite"

# SQLite database for local development (file lives at prisma/dev.db).
DATABASE_URL="file:./dev.db"

# Secret used to sign magic-link + session tokens. The insecure fallback is
# only tolerated when NODE_ENV != production; a hosted deploy MUST set a strong
# value or it will refuse to sign sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"

# Base URL used when building shareable / magic links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Plan for this install: "free" (default), "pro", or "team". Local installs are
# fully functional on free; set "pro"/"team" to unlock cloud sync + API tokens.
# SCHEMNOTES_PLAN="free"

# Optional: absolute path to kicad-cli, used to render native KiCad (.kicad_sch)
# uploads to SVG. Auto-detected from a standard KiCad install if left unset.
# KICAD_CLI="C:/Program Files/KiCad/10.0/bin/kicad-cli.exe"

# ---------------------------------------------------------------------------
# Cloud deployment (Postgres — enables cross-device sync). See DEPLOY.md.
# ---------------------------------------------------------------------------
# DB_PROVIDER="postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/schemnotes?sslmode=require"
# AUTH_SECRET="<64 hex chars from the generate command above>"
# NEXT_PUBLIC_APP_URL="https://schemnotes.example.com"
# SCHEMNOTES_PLAN="pro"
