# Copy this file to `.env` and adjust as needed.

# SQLite database for local development (file lives at prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Secret used to sign magic-link + session tokens (added in the auth phase).
# Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me"

# Base URL used when building shareable / magic links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: absolute path to kicad-cli, used to render native KiCad (.kicad_sch)
# uploads to SVG. Auto-detected from a standard KiCad install if left unset.
# KICAD_CLI="C:/Program Files/KiCad/10.0/bin/kicad-cli.exe"
